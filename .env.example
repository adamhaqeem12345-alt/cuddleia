
# PayPal API Credentials
# IMPORTANT: The Client ID must be prefixed with NEXT_PUBLIC_ to be accessible on the client-side for the PayPal script.
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID

# Zoho Mail SMTP Credentials (for sending order confirmation emails)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# The public URL of your site (used for PayPal return URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
