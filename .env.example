# PayPal API Credentials
# Get these from your PayPal Developer Dashboard
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optional: Set to 'live' for production
# PAYPAL_API_ENV=sandbox

# Email Credentials (using Zoho in this example)
# These are required for sending order confirmation emails
EMAIL_USER=
EMAIL_PASS=

# Public URL of your site
# Required for PayPal redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
