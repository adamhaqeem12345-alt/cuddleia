# Firebase - (No credentials needed here, handled by Firebase Hosting environment)

# PayPal
# Get these from your PayPal Developer Dashboard (https://developer.paypal.com)
# Use Sandbox credentials for testing and Live credentials for production.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# For Sandbox: https://api-m.sandbox.paypal.com
# For Live: https://api-m.paypal.com
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com

# Zoho Mail
# App Password generated from your Zoho account security settings
ZOHO_MAIL_USER=your-email@zoho.com
ZOHO_MAIL_PASSWORD=your-zoho-app-password

# Application URL
# This is required for PayPal redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
