# PayPal API Credentials
# IMPORTANT: The Client ID MUST be prefixed with NEXT_PUBLIC_ to be accessible on the client-side for the PayPal script.
PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_SECRET="YOUR_PAYPAL_CLIENT_SECRET"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"

# Site URL for redirects
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email credentials for sending order confirmations
EMAIL_USER="your-email@example.com"
EMAIL_PASS="your-email-password-or-app-key"
