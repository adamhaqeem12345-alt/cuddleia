# Zoho Mail Credentials
ZOHO_MAIL_USER=your_email@example.com
ZOHO_MAIL_PASS=your_zoho_app_password

# ToyyibPay Credentials
TOYYIBPAY_SECRET=your_toyyibpay_secret_key
TOYYIBPAY_CATEGORY_CODE=your_toyyibpay_category_code

# PayPal Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# Application URL
# Use http://localhost:3000 for local development
# Use your production domain (e.g., https://www.cuddleia.com) for the live site
NEXT_PUBLIC_APP_URL=http://localhost:3000
