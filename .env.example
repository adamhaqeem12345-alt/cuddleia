# This is an example file. Copy this to .env.local and fill in your actual credentials.
# IMPORTANT: .env.local should NOT be committed to version control.

# Zoho Mail Credentials for sending order confirmation emails
ZOHO_MAIL_USER=your_email@example.com
ZOHO_MAIL_PASS=your_zoho_app_password

# ToyyibPay Credentials for Malaysian payments
TOYYIBPAY_SECRET=your_toyyibpay_secret_key
TOYYIBPAY_CATEGORY_CODE=your_toyyibpay_category_code

# PayPal Credentials for international payments
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
NEXT_PUBLIC_PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Application URL. Use http://localhost:3000 for local development.
# For production, use your live website URL (e.g., https://www.cuddleia.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
