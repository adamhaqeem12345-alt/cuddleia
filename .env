# IMPORTANT: You must generate an "App Password" from your Zoho account settings
# and use it for ZOHO_MAIL_APP_PASSWORD. Your regular login password will not work.
# Go to: Zoho Mail -> Settings -> Security -> App Passwords -> Generate New Password.
ZOHO_MAIL_USER="your-zoho-email@zoho.com"
ZOHO_MAIL_APP_PASSWORD="your-zoho-app-password"

# For detailed instructions, visit: 
# https://www.zoho.com/mail/help/adminconsole/org-app-passwords.html

# PayPal Credentials
# Make sure to get these from your PayPal Developer Dashboard
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"

# ToyyibPay Credentials
# Make sure to get these from your ToyyibPay Dashboard
TOYYIBPAY_SECRET_KEY="your-toyyibpay-secret-key"
TOYYIBPAY_CATEGORY_CODE="your-toyyibpay-category-code"
