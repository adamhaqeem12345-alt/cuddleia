/**
 * @fileoverview Firestore Security Rules for the Global Cart application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for shopping carts and payments,
 * while allowing public read access to product categories and products.
 *
 * Data Structure:
 * - /categories/{categoryId}: Stores category data. Publicly readable.
 * - /products/{productId}: Stores product data. Publicly readable.
 * - /users/{userId}/shopping_cart/{shoppingCartId}: Each user has their own shopping cart. Only the user can access their own cart.
 * - /users/{userId}/payments/{paymentId}: Stores payment history for each user. Only the user can access their own payment history.
 *
 * Key Security Decisions:
 * - Public read access to categories and products.
 * - Strict user-ownership for shopping carts and payments.
 * - Denormalization is not explicitly needed in this data model based on the structure and relationships.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to categories.
     * @path /categories/{categoryId}
     * @allow (get, list) Any user can read category data.
     * @deny (create, update, delete) No user can create, update, or delete category data through the client.
     * @principle Allows public read access; restricts write access.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to products.
     * @path /products/{productId}
     * @allow (get, list) Any user can read product data.
     * @deny (create, update, delete) No user can create, update, or delete product data through the client.
     * @principle Allows public read access; restricts write access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Enforces user-ownership for shopping carts.
     * @path /users/{userId}/shopping_cart/{shoppingCartId}
     * @allow (get, list) User 'abc' can read their own shopping cart.
     * @allow (create) User 'abc' can create a shopping cart with userId 'abc'.
     * @allow (update) User 'abc' can update their own existing shopping cart.
     * @allow (delete) User 'abc' can delete their own existing shopping cart.
     * @deny (get, list) User 'def' cannot read user 'abc's shopping cart.
     * @deny (create, update, delete) User 'def' cannot create, update, or delete user 'abc's shopping cart.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/shopping_cart/{shoppingCartId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for payments.
     * @path /users/{userId}/payments/{paymentId}
     * @allow (get, list) User 'abc' can read their own payment data.
     * @allow (create) User 'abc' can create a payment with userId 'abc'.
     * @allow (update) User 'abc' can update their own existing payment data.
     * @allow (delete) User 'abc' can delete their own existing payment data.
     * @deny (get, list) User 'def' cannot read user 'abc's payment data.
     * @deny (create, update, delete) User 'def' cannot create, update, or delete user 'abc's payment data.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/payments/{paymentId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}