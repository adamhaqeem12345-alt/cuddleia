/**
 * @fileoverview Firestore Security Rules for the Global Cart application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for shopping carts and payments,
 * while allowing public read access to product and category information.
 *
 * Data Structure:
 * - Categories: Stored in a top-level `/categories` collection. Publicly readable.
 * - Products: Stored in a top-level `/products` collection. Publicly readable.
 * - Shopping Carts: Each user has a private shopping cart stored under `/users/{userId}/shopping_cart/{shoppingCartId}`.
 * - Payments: Each user has a private payment history stored under `/users/{userId}/payments/{paymentId}`.
 *
 * Key Security Decisions:
 * - Categories and Products are publicly readable to facilitate browsing.
 * - User-specific data (shopping carts and payments) is strictly controlled, with each user only able to access their own data.
 * - Listing of user-specific shopping carts and payments is allowed only for the owner.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to categories. Only allows create, update, and delete by authenticated users.
     * @path /categories/{categoryId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Allows public read access to categories for browsing.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to products. Only allows create, update, and delete by authenticated users.
     * @path /products/{productId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Allows public read access to products for browsing.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Enforces user-ownership for shopping carts. Only the owner can create, read, update, or delete their cart.
     * @path /users/{userId}/shopping_cart/{shoppingCartId}
     * @allow (create, get, list, update, delete) when the user ID matches the authenticated user's ID.
     * @deny (create, get, list, update, delete) when the user ID does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes, restricts access to a user's own shopping cart.
     */
    match /users/{userId}/shopping_cart/{shoppingCartId} {
      allow get, list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for payments. Only the owner can create, read, update, or delete their payment information.
     * @path /users/{userId}/payments/{paymentId}
     * @allow (create, get, list, update, delete) when the user ID matches the authenticated user's ID.
     * @deny (create, get, list, update, delete) when the user ID does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes, restricts access to a user's own payment history.
     */
    match /users/{userId}/payments/{paymentId} {
      allow get, list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}