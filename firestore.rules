
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to most collections
    match /{document=**} {
      allow read: if true;
    }

    // Allow anyone to create an order
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can update/delete
    }
  }
}
